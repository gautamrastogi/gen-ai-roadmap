# ============================================================
# GenAI Roadmap — Local Agent Configuration Template
# Copy this to config.env and customize for your environment
# ============================================================

# --- Local Agent MCP Server ---
# Base directory for MCP server files (relative to project root)
MCP_BASE_DIR="projects/local-agent"

# Workspace root (auto-detected if not set)
WORKSPACE_ROOT=""

# LM Studio API endpoint
LM_STUDIO_BASE_URL="http://127.0.0.1:1234"

# Logging configuration
LOG_LEVEL="INFO"

# --- OpenAI (Phase 2+) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_ORG_ID=org-your-org-here          # optional

# --- Anthropic / Claude (Phase 4+) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here   # optional

# --- LangSmith Tracing (Phase 5) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your-key-here
LANGCHAIN_PROJECT=genai-roadmap

# --- Langfuse (Phase 5 — open-source alternative to LangSmith) ---
LANGFUSE_PUBLIC_KEY=pk-your-key
LANGFUSE_SECRET_KEY=sk-your-key
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Local Models (Phase 2+, no key needed) ---
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Qdrant (Phase 3 — if using cloud) ---
QDRANT_URL=https://your-cluster.qdrant.tech
QDRANT_API_KEY=your-qdrant-key

# --- HuggingFace (Phase 8 — for model downloads) ---
HF_TOKEN=hf_your-token-here

# --- App Settings ---
ENVIRONMENT=development