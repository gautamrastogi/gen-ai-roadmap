# ============================================================
# GenAI Roadmap - Local Configuration Template
#
# Copy this file to config.env for repo-level helper scripts:
#   cp templates/config.env.template config.env
#
# Keep real values only in config.env, .env, or per-project .env files.
# Those files are gitignored. This template should stay public-safe.
# ============================================================

# --- Repo / local-agent paths ---
# Usually safe to leave these blank/defaulted.
MCP_BASE_DIR="projects/local-agent"
WORKSPACE_ROOT=""

# --- Local model provider ---
# The local-agent and roadmap coach use LOCAL_MODEL_* first.
# Ollama default:
LOCAL_MODEL_PROVIDER="ollama"
LOCAL_MODEL_BASE_URL="http://127.0.0.1:11434"
LOCAL_MODEL_NAME="gemma4:latest"

# LM Studio alternative:
# LOCAL_MODEL_PROVIDER="lmstudio"
# LOCAL_MODEL_BASE_URL="http://127.0.0.1:1234"
# LOCAL_MODEL_NAME="your-loaded-model-name"

# Backward-compatible aliases used by some projects/tools.
OLLAMA_BASE_URL="http://127.0.0.1:11434/v1"
LM_STUDIO_BASE_URL="http://127.0.0.1:1234"

# --- Cloud model providers ---
# Fill only what you need. Leave blank otherwise.
OPENAI_API_KEY=""
OPENAI_ORG_ID=""
ANTHROPIC_API_KEY=""
HF_TOKEN=""
GITHUB_TOKEN=""

# --- Vector stores / RAG ---
QDRANT_URL=""
QDRANT_API_KEY=""

# --- Observability / evals ---
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="genai-roadmap"
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# --- App settings ---
LOG_LEVEL="INFO"
ENVIRONMENT="development"
