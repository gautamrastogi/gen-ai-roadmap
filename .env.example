# ============================================================
# GenAI Roadmap - Environment Variables Template
#
# Copy to .env and fill only the values you need:
#   cp .env.example .env
#
# Never commit .env. It is ignored by git.
# ============================================================

# --- Local models ---
LOCAL_MODEL_PROVIDER="ollama"
LOCAL_MODEL_BASE_URL="http://127.0.0.1:11434"
LOCAL_MODEL_NAME="qwen2.5:1.5b"
OLLAMA_BASE_URL="http://127.0.0.1:11434/v1"
LM_STUDIO_BASE_URL="http://127.0.0.1:1234"

# --- Cloud model providers ---
OPENAI_API_KEY=""
OPENAI_ORG_ID=""
ANTHROPIC_API_KEY=""
HF_TOKEN=""
GITHUB_TOKEN=""

# --- Vector stores / RAG ---
QDRANT_URL=""
QDRANT_API_KEY=""

# --- Observability / evals ---
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="genai-roadmap"
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# --- App settings ---
LOG_LEVEL="INFO"
ENVIRONMENT="development"
