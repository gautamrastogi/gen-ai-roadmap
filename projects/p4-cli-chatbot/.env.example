# Auth priority:
# 1. OPENAI_BASE_URL (local/OpenAI-compatible server; API key can be dummy)
# 2. HF_TOKEN (HuggingFace router)
# 3. GITHUB_TOKEN (GitHub Models)
# 4. OPENAI_API_KEY (OpenAI direct)

# Local-first default:
OPENAI_BASE_URL=http://127.0.0.1:11434/v1   # Ollama
OPENAI_API_KEY=local-model
MODEL=gemma4:latest

# LM Studio alternative:
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_API_KEY=local-model
# MODEL=your-loaded-model-name

HF_TOKEN=
GITHUB_TOKEN=

TEMPERATURE=0.7
MAX_TOKENS=700
SESSION_PATH=sessions/default.json
