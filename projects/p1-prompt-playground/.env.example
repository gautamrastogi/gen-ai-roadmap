# ── Option A: HuggingFace (recommended — works on Danske/corporate networks) ───
# Free tier. Get token at: huggingface.co/settings/tokens → New token (read)
HF_TOKEN=hf_...

# ── Option B: Direct OpenAI API key (home / personal network only) ──────────
# OPENAI_API_KEY=sk-...

# ── Optional overrides ──────────────────────────────────────────────────────
# OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct   # any HF model org/name
# MAX_TOKENS=256
# TEMPERATURE=0.7
