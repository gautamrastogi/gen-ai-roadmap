# Default local-first path: Ollama OpenAI-compatible API
EXTRACTION_MODE=prompt
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=local-model
MODEL=gemma4:latest

# Modes:
# prompt           Local-friendly. Prompt asks for JSON, app validates after.
# chat_schema      Chat Completions with response_format json_schema.
# responses_schema OpenAI Responses API with text.format json_schema.

# OpenAI structured output path:
# EXTRACTION_MODE=responses_schema
# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# MODEL=gpt-4.1-mini

TEMPERATURE=0.1
MAX_TOKENS=1200
MAX_INPUT_TOKENS=8000
REQUEST_TIMEOUT_SECONDS=60
