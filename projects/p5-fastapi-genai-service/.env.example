# Default local-first path: Ollama OpenAI-compatible API
LLM_ADAPTER=chat
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=local-model
MODEL=qwen2.5:1.5b

# Alternatives:
# LM Studio:
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_API_KEY=local-model
#
# OpenAI Responses API:
# LLM_ADAPTER=responses
# OPENAI_BASE_URL=
# OPENAI_API_KEY=sk-...
# MODEL=gpt-4.1-mini
#
# HuggingFace Router / GitHub Models with chat adapter:
# HF_TOKEN=
# GITHUB_TOKEN=

TEMPERATURE=0.2
MAX_TOKENS=700
MAX_INPUT_TOKENS=6000
REQUEST_TIMEOUT_SECONDS=60

# Optional token economics, dollars per 1M tokens
INPUT_TOKEN_PRICE_PER_1M=
OUTPUT_TOKEN_PRICE_PER_1M=
