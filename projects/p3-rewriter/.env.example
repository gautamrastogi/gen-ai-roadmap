# ── HuggingFace (recommended — works on many corporate networks) ───────────
# Free token at: huggingface.co/settings/tokens → New token (read)
HF_TOKEN=

# ── Direct OpenAI API key (home / personal network only) ────────────────────
OPENAI_API_KEY=

# ── Optional overrides ──────────────────────────────────────────────────────
# OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct
# MAX_TOKENS=512
# TEMPERATURE=0.4
