# Python
__pycache__/
.mypy_cache/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
.venv-ml/
venv/
env/
ENV/
*/.venv/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# IDE / editors
.cursor/
.idea/
.vscode/
*.swp
*.swo
*~

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# SQLite / databases
*.db
*.sqlite
*.sqlite3

# Log files
*.log
logs/

# Test artifacts
test_output.txt
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Local planning notes
2026-focus-private.md
projects/local-agent/roadmap-progress.local.json

# Dashboard runtime files
projects/dashboard/tracker.db
projects/dashboard/launchd.out.log
projects/dashboard/launchd.err.log

# Environment / secrets
.env
.env.*
!.env.example
config.env

# API keys / secrets
*.pem
*.key
*.p12
secrets.json

# OS / temp
*.tmp
*.bak
*.orig
Thumbs.db

# Node (if any JS projects added)
node_modules/
npm-debug.log*

# ML model files (large — don't commit)
*.gguf
*.safetensors
*.bin
*.pt
*.pth
models/
adapters/

# HuggingFace cache
~/.cache/huggingface/

# Output / generated
output/
generated/
artifacts/
*.mp3
*.mp4
*.wav

# Docker
.docker/
